public static void playGame( Integer[][] arena ){


        //For this task you don't need to create any new 2D array
        //just print the result inside the function
        int row= arena.length;
        int cols = arena[0].length;
        int total=0;
        for(int i=0;i<row;i++){
          for (int j=0; j<cols ; j++){
          if( arena[i][j]%50==0&& arena[i][j]!=0){
              int count =0;
              if(i>0&& arena[i-1][j]==2){
                  count++;
                }
              if ( i<row-1&& arena[i+1][j]==2){
                count++;
              }
              if(j>0&& arena[i][j-1]==2){
                count++;
              }
                 if(j<cols-1&&arena[i][j+1]==2){
                   count++;
                 }
                 total+=(count*2);
                 }
}
}
      if(total>=10){
  System.out.println( "points Gained:"+ total+"your team has survived the game .");
      }
  else{
    System.out.println( "points Gained:"+ total+"Your team is out.");
   
    }
                 
