 public static Integer[][] compressMatrix( Integer[][] matrix ){


        //For this task you'll need to create new 2D array
       
        int row = matrix.length/2;
        int cols = matrix[0].length/2;
        Integer[][]compmatrix = new Integer[row][cols];
       
        for (int i=0; i<row;i++){
            for (int j=0; j<cols;j++){
        int m= i*2;
        int n =j*2;
        compmatrix[i][j]= matrix[m][n]+
                          matrix [m+1][n]+
                          matrix[m][n+1]+
                          matrix [m+1][n+1];
            }
}


   
   
        //remove the line below and return the newly created Compressed 2D matrix
        return compmatrix;
    }




